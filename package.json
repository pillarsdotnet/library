{
  "name": "home-library",
  "version": "2.1.0",
  "description": "Catalogue books in a private library with ISBN scanning, location tracking, and SQLite storage.",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"public/**/*.css\"",
    "lint:fix": "eslint . --fix && stylelint \"public/**/*.css\" --fix",
    "test": "node --test",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ericblade/quagga2": "^1.12.1",
    "better-sqlite3": "^11.10.0",
    "cropperjs": "^1.6.2",
    "express": "^4.21.2",
    "fflate": "^0.8.3",
    "html5-qrcode": "^2.3.8",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "puppeteer-core": "^25.3.0",
    "stylelint": "^16.12.0",
    "stylelint-config-standard": "^36.0.1"
  }
}
